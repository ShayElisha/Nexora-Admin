# SuperAdmin backend environment variables (set these in Vercel Project Settings)
MONGO_URI=your_mongodb_atlas_connection_string
JWT_SECRET=your_jwt_secret
NODE_ENV=production

# Comma-separated list of allowed frontend origins (your SuperAdmin Vercel domain)
FRONTEND_URL=https://your-superadmin-domain.vercel.app

# Email (nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
